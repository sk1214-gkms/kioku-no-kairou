{
  "id": "r8",
  "name": "R8 鏡の間",
  "memory_id": "mem_r8",
  "intro": "鏡の間。明かりを消したとき、鏡は“本当の私”を映すという。",
  "hints": [
    {
      "t": "明るい鏡は嘘しか映さない。まず光を断て。",
      "done_when": {
        "state": [
          {
            "interactable": "lamp",
            "state": "off"
          }
        ]
      }
    },
    {
      "t": "西の照明を消し、東の鏡と向き合う。",
      "done_when": {
        "state": [
          {
            "interactable": "lamp",
            "state": "off"
          }
        ]
      }
    },
    "鏡の嘘には、各部屋で“直視”した記憶を突きつけよ。",
    "「甥が」には犯人の記憶、「凶器は」には凶器の記憶、「見ていた」にはあの夜の記憶。",
    "直視していない記憶は突きつけられない。出せないなら目を背けよ（否定で脱出）。"
  ],
  "start_node": "at_door",
  "viewpoints": {
    "at_switch": {
      "label": "西：照明",
      "bg": "r8_switch",
      "objects": [
        {
          "id": "lamp",
          "rect": [
            280,
            120,
            55,
            90
          ],
          "label": "照明スイッチ",
          "toggle": true,
          "states": [
            "on",
            "off"
          ]
        }
      ]
    },
    "at_mirror": {
      "label": "北：肖像",
      "bg": "r8_mirror",
      "objects": [
        {
          "id": "portrait",
          "rect": [
            110,
            120,
            140,
            160
          ],
          "label": "肖像画",
          "reveal": "穏やかな氷室の肖像。だが…明かりを消すと？"
        },
        {
          "id": "fogmirror",
          "rect": [
            20,
            150,
            80,
            150
          ],
          "label": "曇った小鏡",
          "reveal": "曇った小鏡。そこには優しい嘘が映る：『お前は救済者だ』。直視すべきは、こちらではない。",
          "reveal_hard": "曇った小鏡。優しい嘘だけが映る。"
        },
        {
          "id": "mirror_whisper",
          "rect": [
            120,
            300,
            130,
            60
          ],
          "label": "小鏡の囁き",
          "show_when": {
            "flags": [
              "ow_culprit"
            ]
          },
          "reveal": "曇った小鏡が、上機嫌に囁く。『ほら、犯人は決まった。あの甥だよ』——妙に、軽い声で。",
          "reveal_hard": "小鏡が囁く。『犯人は決まった』。"
        },
        {
          "id": "mirror_n",
          "rect": [
            110,
            150,
            150,
            170
          ],
          "label": "鏡",
          "requires_state": [
            {
              "interactable": "lamp",
              "state": "off"
            }
          ],
          "reveal": "暗がりの鏡に映るのは、返り血を浴びた私自身。それが、嗤っている。",
          "dialogue": {
            "speaker": "鏡の中の私",
            "lines": [
              {
                "say": "落ち着け。お前は無実だ。手を下したのは、あの甥だろう？",
                "press": "kept_culprit",
                "rebut": "——いや。消去法の果てに残ったのは、私だった。",
                "fail": "…反論の、根拠が無い。"
              },
              {
                "say": "凶器も甥のナイフだ。お前は医者じゃないか。",
                "press": "kept_weapon",
                "rebut": "——違う。この手が握っていたのは、ペーパーナイフ。その感触が、まだ残っている。",
                "fail": "…言い返せない。"
              },
              {
                "say": "あの夜、お前はただ見ていただけ。そうだろう？",
                "press": "kept_truth",
                "rebut": "——見ていた、だと？ この手が、確かに動いたんだ。",
                "fail": "…記憶が、霧の中だ。"
              }
            ],
            "on_break": {
              "text": "鏡が砕け散る。私は、返り血を浴びた自分を——受け入れた。",
              "flag": "s_r8_confront",
              "delta": 1,
              "win": true
            },
            "on_yield": {
              "text": "私は鏡から目を背けた。あれは私じゃない。そうだ、私じゃない。",
              "flag": "s_r8_evade",
              "delta": -1,
              "win": true
            }
          },
          "normal_only": true,
          "show_when": {
            "state": [
              {
                "interactable": "lamp",
                "state": "off"
              }
            ]
          }
        },
        {
          "id": "mirror_h",
          "rect": [
            110,
            150,
            150,
            170
          ],
          "label": "鏡",
          "requires_state": [
            {
              "interactable": "lamp",
              "state": "off"
            }
          ],
          "reveal": "暗がりの鏡。返り血の私が、今度は理路整然と語りかけてくる。",
          "dialogue": {
            "speaker": "鏡の中の私",
            "lines": [
              {
                "say": "血の匂いがするな。だがそれは“あの男”の罪の匂いだ。お前は無実。",
                "press": "kept_culprit",
                "rebut": "——いや。消去法の果てに残ったのは、私だ。",
                "fail": "…誰の罪か、言い返せない。"
              },
              {
                "say": "お前の手は、繊細な医者の手。重い凶器など振るえぬ。",
                "press": "kept_weapon",
                "rebut": "——この手が握ったのは、ペーパーナイフ。その感触が、まだ残っている。",
                "fail": "…手の記憶が、霧の中だ。"
              },
              {
                "say": "そもそもお前は、あの夜あの場にいたのか？ ただの悪夢かもしれぬ。",
                "press": "kept_truth",
                "rebut": "——いた。この手が、確かに動いた。",
                "fail": "…あの夜が、思い出せない。"
              },
              {
                "say": "……ならば問おう。お前が“救済”と呼ぶそれは、本当に罪か？",
                "press": "kept_truth",
                "rebut": "——救済という名の、殺人だ。私は、それを直視する。",
                "fail": "…言葉に、詰まる。"
              }
            ],
            "on_break": {
              "text": "鏡が砕け散る。私は、返り血を浴びた自分を——受け入れた。",
              "flag": "s_r8_confront",
              "delta": 1,
              "win": true
            },
            "on_yield": {
              "text": "私は鏡から目を背けた。あれは私じゃない。そうだ、私じゃない。",
              "flag": "s_r8_evade",
              "delta": -1,
              "win": true
            }
          },
          "hard_only": true,
          "show_when": {
            "state": [
              {
                "interactable": "lamp",
                "state": "off"
              }
            ]
          }
        }
      ]
    },
