{
  "thresholds": {
    "memory_high": 70,
    "memory_low": 40
  },
  "rules": [
    {
      "branch": "police",
      "conditions": [
        { "when": "deduction_correct == true && memory_score >= memory_high", "ending": "A+", "title": "真・無実の証明", "type": "true_perfect", "text": "t_end_A_true" },
        { "when": "memory_score >= memory_high", "ending": "A",  "title": "無実の証明",   "type": "true",   "text": "t_end_A" },
        { "when": "memory_score <  memory_high", "ending": "A'", "title": "疑惑の保護",   "type": "bitter", "text": "t_end_A2" }
      ]
    },
    {
      "branch": "flee",
      "conditions": [
        { "when": "memory_score <  memory_low", "ending": "B",  "title": "終わらない逃亡", "type": "bad",    "text": "t_end_B",  "loop_to_stage": 1 },
        { "when": "memory_score >= memory_low", "ending": "B'", "title": "逃亡の代償",     "type": "bitter", "text": "t_end_B2" }
      ]
    },
    {
      "branch": "backdoor",
      "conditions": [
        { "when": "has_culprit_evidence == true",  "ending": "C",  "title": "共犯者の告発", "type": "hidden_bitter", "text": "t_end_C" },
        { "when": "has_culprit_evidence == false", "ending": "C'", "title": "ただの逃走",   "type": "normal",        "text": "t_end_C2" }
      ]
    }
  ],
  "note": "ルールは上から評価し最初に一致したものを採用する。deduction_correct は最終室の任意推理（7.3）で立つフラグ。閾値はプレイテストで調整可。"
}
