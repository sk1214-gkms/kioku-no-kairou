        <mxCell id="d5" value="周回反応：R4逃避→『耳の奥』／R4直面→『残響』が出現　※変種謎候補（←R4分岐・R7の手応え後）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="900" y="586" width="520" height="76" as="geometry"/></mxCell>

        <mxCell id="r6" value="R6 記録室〔N〕 ① ★最難" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="560" y="690" width="300" height="76" as="geometry"/></mxCell>
        <mxCell id="p6" value="対峙（消去法）：乙の改竄を看破→原本21:00→甲19:00・甥=門施錠→残るは私 → number『0345』　※Hard：二重の改竄看破" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="60" y="690" width="460" height="76" as="geometry"/></mxCell>
        <mxCell id="d6" value="①推理の結論：直視→kept_culprit ／ 書き換え『甥』→ow_culprit（錠が独りでに開く）　→R7変種・R8小鏡が反応" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="900" y="690" width="520" height="76" as="geometry"/></mxCell>

        <mxCell id="r7" value="R7 廊下〔I〕 ① ★変種実装済" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="560" y="794" width="300" height="76" as="geometry"/></mxCell>
        <mxCell id="p7" value="足跡選別：規則『往復＋還り乱れ』→白い足跡→血痕03:45＋半時→number『0415』　★変種：ow_culprit周＝現場が編集（掠れた足跡＋囮の血足跡）・答不変" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="60" y="794" width="460" height="76" as="geometry"/></mxCell>
        <mxCell id="d7" value="①凶器の記憶：直視→kept_weapon ／ 書き換え→ow_weapon（審判の問2を左右）。kept_truthで『壁の滲み』" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="900" y="794" width="520" height="76" as="geometry"/></mxCell>

        <mxCell id="r8" value="R8 鏡の間〔分岐②〕★対峙" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="560" y="898" width="300" height="76" as="geometry"/></mxCell>
        <mxCell id="p8" value="消灯→鏡と対峙：鏡の嘘×3に“直視した記憶(kept_*)”を突きつけ全論破　※Hard：4手目の追い詰め" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="60" y="898" width="460" height="76" as="geometry"/></mxCell>
        <mxCell id="d8" value="分岐②：受容→s_r8_confront(+1) ／ 目を背ける→s_r8_evade(−1)（突きつけ不可でも否定で脱出可）　→R10が反応。ow_culprit周は小鏡が囁く" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="900" y="898" width="520" height="76" as="geometry"/></mxCell>

        <mxCell id="r9" value="R9 標本室〔G〕★追跡" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="560" y="1002" width="300" height="76" as="geometry"/></mxCell>
        <mxCell id="p9" value="合成：空シリンジ＋針→＋薬液→『完全な注射器』→南扉に挿す" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="60" y="1002" width="460" height="76" as="geometry"/></mxCell>
        <mxCell id="d9" value="隠し：追跡（影を方向で追う・N5手/H7手＋攪乱）→『金属製の筒』has_culprit_evidence ＝ S結末の鍵（任意）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="900" y="1002" width="520" height="76" as="geometry"/></mxCell>

        <mxCell id="r10" value="R10 監視室〔E〕★scrub" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="1106" width="300" height="76" as="geometry"/></mxCell>
        <mxCell id="p10" value="通電→記録をスクラブ再生：刃物の瞬間複数から“異音03:45”と重なる一点だけ保存（N±1分/H±0・罠：04:15白衣の袖）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="60" y="1106" width="460" height="76" as="geometry"/></mxCell>
        <mxCell id="d10" value="周回反応：s_r8_confrontで『砂嵐の顔』　※変種謎候補（←R3①・R7の手応え後）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="900" y="1106" width="520" height="76" as="geometry"/></mxCell>

        <mxCell id="r11" value="R11 手術室〔D〕★手順" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="1210" width="300" height="76" as="geometry"/></mxCell>
        <mxCell id="p11" value="sequence：各器具の相対順を読解→カルテ→手洗い→無影灯→麻酔→メス→縫合（囮：止血鉗子／H＋洗浄）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="60" y="1210" width="460" height="76" as="geometry"/></mxCell>
        <mxCell id="d11" value="—（決断なし。部屋そのものが暗号＝手がかりは説明されない）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="900" y="1210" width="520" height="76" as="geometry"/></mxCell>

        <mxCell id="r12" value="R12 証拠保管室〔分岐③〕" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="560" y="1314" width="300" height="76" as="geometry"/></mxCell>
        <mxCell id="p12" value="sequence：時系列＝約束→施錠→凶行→甥の目撃→記録（捏造2つ除外：甥の侵入・自殺偽装／H＝3つ）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="60" y="1314" width="460" height="76" as="geometry"/></mxCell>
        <mxCell id="d12" value="分岐③（03:45の記録）：暴く→s_r12_confront(+1) ／ 目を背ける→s_r12_evade(−1)。直面×2で『検視官の付記』" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="900" y="1314" width="520" height="76" as="geometry"/></mxCell>

        <mxCell id="r13" value="R13 最後の扉〔H収束〕" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="1418" width="300" height="76" as="geometry"/></mxCell>
        <mxCell id="p13" value="断片6つ→ME＋MO＋RY＝text『MEMORY』（罠：DE／OR／GE）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="60" y="1418" width="460" height="76" as="geometry"/></mxCell>
        <mxCell id="d13" value="周回反応：上書き×2で罠刻印が“馴染む”。クリア→GEDÄCHTNIS→VERLUST収束演出へ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="900" y="1418" width="520" height="76" as="geometry"/></mxCell>

        <mxCell id="verlust" value="VERLUST 収束演出（真相の自覚）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="560" y="1544" width="300" height="56" as="geometry"/></mxCell>

        <mxCell id="judg" value="30号室・最後の審判（3問×3択・証拠連結）※突入時に審判チェックポイント保存&#10;問1 真犯人：嘘＝甥〔無条件〕／ 真実＝私〔要kept_culprit〕／ 囮＝使用人〔無条件〕&#10;問2 凶器：嘘＝甥のナイフ〔無条件〕／ 真実＝ペーパーナイフ〔要kept_weapon〕／ シリンジ〔要 金属筒〕&#10;問3 あの夜：嘘＝目撃しただけ〔無条件〕／ 真実＝この手で刺した〔要kept_truth〕／ 囮＝憶えていない&#10;※嘘・囮は無条件＝嘘に根拠は要らない。真実は“直視した記憶”が必要（書き換えた者は真実を主張できない）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;spacingTop=4;fontSize=11;" vertex="1" parent="1"><mxGeometry x="360" y="1650" width="700" height="150" as="geometry"/></mxCell>

        <mxCell id="decide" value="結末決定（優先順）　①脳死→D ＞ ②凶器=シリンジ＋金属筒→S ＞ ③全問真実＋全直面→True&#10;＞ ④嘘M=3 →（全逃避ならA+／それ以外A） ＞ ⑤M&lt;3 →（全逃避ならB／それ以外C）&#10;スコア＝作話完全度 I=(T×M)(1+E/3)　※E=逃避＋①上書き回数(0..3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;spacingTop=4;fontSize=11;" vertex="1" parent="1"><mxGeometry x="360" y="1850" width="700" height="96" as="geometry"/></mxCell>

        <mxCell id="endAp" value="A+&#10;完璧な偽物" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="1996" width="190" height="76" as="geometry"/></mxCell>
