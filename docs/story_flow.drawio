        <mxCell id="p1" value="探索：洗面台の下→小箱→『小さな鍵』→南扉（要アイテム）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="60" y="170" width="460" height="76" as="geometry"/></mxCell>
