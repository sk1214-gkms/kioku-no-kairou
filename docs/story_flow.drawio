        <mxCell id="modes" value="5モード：ストーリー(時間∞・最終ヒント有) / ノーマル(最終ヒント封印) / ハード(暗号化・囮増・対峙/追跡/scrub強化) / ＋時間=N15分・H12分(結末Dが解禁)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1"><mxGeometry x="900" y="40" width="520" height="56" as="geometry"/></mxCell>

