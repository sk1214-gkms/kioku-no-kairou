        <mxCell id="endS" value="S 深淵の白&#10;（安楽死の真相）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="884" y="1996" width="190" height="76" as="geometry"/></mxCell>
