        <mxCell id="e_s" value="S 深淵の白〔隠し〕（教授自殺・死体損壊・自らの目を潰す）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" vertex="1" parent="1"><mxGeometry x="730" y="1104" width="300" height="40" as="geometry" /></mxCell>
        <mxCell id="e_true" value="True 白慈の審判〔隠し〕（罪を引き受け自首・人間への回帰）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" vertex="1" parent="1"><mxGeometry x="730" y="1156" width="300" height="40" as="geometry" /></mxCell>
