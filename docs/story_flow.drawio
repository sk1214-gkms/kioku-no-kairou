        <mxCell id="r8" value="R8 鏡の間　◆分岐②（直面／逃避）　※文字なし" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" vertex="1" parent="1"><mxGeometry x="330" y="550" width="300" height="38" as="geometry" /></mxCell>
