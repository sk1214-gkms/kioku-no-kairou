        <mxCell id="reveal" value="アナグラム収束：断片 → Gedächtnis（抑圧Hが血色で嵌まる）→ VERLUST" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2540;strokeColor=#000000;fontColor=#ffffff;fontStyle=1" vertex="1" parent="1"><mxGeometry x="320" y="852" width="320" height="42" as="geometry" /></mxCell>
        <mxCell id="judge" value="30号室 確定の儀式&#10;推理3問（真犯人／凶器／あの夜の真相）→ 結論を直視 →［この記憶を、確定する］" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1" vertex="1" parent="1"><mxGeometry x="310" y="912" width="340" height="56" as="geometry" /></mxCell>

        <mxCell id="note_timer" value="脳死カウントダウン（全モード共通・全部屋で進行）&#10;ノーマル1500／タイマー900／ハード720秒&#10;0 になった瞬間 → Ending D（推理に到達できず）" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top" vertex="1" parent="1"><mxGeometry x="20" y="1110" width="300" height="78" as="geometry" /></mxCell>

