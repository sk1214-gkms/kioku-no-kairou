<mxfile host="app.diagrams.net" type="device">
  <diagram id="kioku_confab_flow" name="記憶の回廊 作話システムフロー(現行)">
    <mxGraphModel dx="900" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1120" pageHeight="1360" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="note_title" value="記憶の回廊 ― 作話（Confabulation）システム フロー〔現行実装版 2026-06〕" style="text;html=1;fontStyle=1;fontSize=15;align=left;verticalAlign=middle" vertex="1" parent="1"><mxGeometry x="40" y="20" width="980" height="28" as="geometry" /></mxCell>

        <mxCell id="note_score" value="採点：作話完全度&#10;I = (T × M) × (1 + E/3)&#10;T=生存度(脳死タイマー残)／M=作話正解数(0-3)／E=逃避数(0-3)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top" vertex="1" parent="1"><mxGeometry x="40" y="56" width="320" height="74" as="geometry" /></mxCell>
        <mxCell id="note_glyph" value="符号化：各部屋でトラウマ順に文字を“不規則”点灯&#10;T·S·Ä·C·N·I·G·E·D（9文字／誤認の罠）&#10;→ R13でアナグラム収束 → Gedächtnis（抑圧されたHが嵌まる）→ VERLUST" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top" vertex="1" parent="1"><mxGeometry x="372" y="56" width="360" height="74" as="geometry" /></mxCell>
        <mxCell id="note_branch" value="分岐 ①R4 ②R8 ③R12：&#10;直面(confront+1) か 逃避(evade+1) を蓄積。&#10;結末の振り分けに使用（扉の明示選択は無し＝創発）。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top" vertex="1" parent="1"><mxGeometry x="744" y="56" width="276" height="74" as="geometry" /></mxCell>

        <mxCell id="start" value="覚醒：白い部屋／両手が赤い（蓮見鏡介の脳内）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1"><mxGeometry x="330" y="150" width="300" height="38" as="geometry" /></mxCell>
        <mxCell id="r1" value="R1 白い部屋　［T 点灯］" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1"><mxGeometry x="330" y="200" width="300" height="38" as="geometry" /></mxCell>
        <mxCell id="r2" value="R2 準備室　［S］" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1"><mxGeometry x="330" y="250" width="300" height="38" as="geometry" /></mxCell>
        <mxCell id="r3" value="R3 暗室　［Ä］" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1"><mxGeometry x="330" y="300" width="300" height="38" as="geometry" /></mxCell>
        <mxCell id="r4" value="R4 書斎　◆分岐①（直面／逃避）　※文字なし" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" vertex="1" parent="1"><mxGeometry x="330" y="350" width="300" height="38" as="geometry" /></mxCell>
