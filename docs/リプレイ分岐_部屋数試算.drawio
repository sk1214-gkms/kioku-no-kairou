  <diagram name="v1_完全分岐の部屋数試算_2026-07-02" id="branchcount1">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="1100" pageHeight="1150">
      <root>
        <mxCell id="0"/>
